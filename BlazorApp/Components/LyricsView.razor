@using BlazorApp.Models
@inject IJSRuntime JSRuntime

<section class="lyrics-viewport">
    <div class="lyrics-container">
        @for (int i = 0; i < Lyrics.Count; i++)
        {
            var index = i;
            var line = Lyrics[i];
            <div id="lyric-@index" 
                 class="lyric-line @(ActiveIndex == index ? "active" : "")"
                 @onclick="() => OnLineClick.InvokeAsync(line.Time)">
                @line.Text
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public List<LyricLine> Lyrics { get; set; } = new();
    [Parameter] public int ActiveIndex { get; set; } = -1;
    [Parameter] public EventCallback<double> OnLineClick { get; set; }

    private int _lastActiveIndex = -1;

    protected override async Task OnParametersSetAsync()
    {
        if (ActiveIndex != _lastActiveIndex && ActiveIndex != -1)
        {
            _lastActiveIndex = ActiveIndex;
            await JSRuntime.InvokeVoidAsync("scrollLyricIntoView", $"lyric-{ActiveIndex}");
        }
    }
}
