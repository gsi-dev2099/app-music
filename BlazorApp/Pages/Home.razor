        new() { Time = 217.0, Text = "'Til then, I walk alone" }
    };

    // State owned here; PlayerBar reads via Parameters — no event callbacks needed
    private int activeIndex = -1;
    private double currentTime = 0;
    private double duration = 0;
    private bool isPlaying = false;
    private PlayerBar? playerBar;

    // DotNet reference so JS can call back into this instance
    private DotNetObjectReference<Home>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            // Pass the .NET reference so JS can call OnTimeUpdate without Blazor events
            await JSRuntime.InvokeVoidAsync(
                "initMusicEngine",
                "audio-player",
                "visualizer-canvas",
                _dotNetRef);
        }
    }

    /// <summary>
    /// Called by AudioEngine.js every 250ms via DotNet.invokeMethodAsync.
    /// Runs fully outside Blazor's event system — audio element is never touched.
    /// </summary>
    [JSInvokable]
    public void OnTimeUpdate(double time, double totalDuration, bool playing)
    {
        currentTime = time;
        duration = totalDuration;
        isPlaying = playing;

        int newIndex = -1;
        for (int i = 0; i < lyricsData.Count; i++)
        {
            if (time >= lyricsData[i].Time) newIndex = i;
            else break;
        }

        if (newIndex != activeIndex)
        {
            activeIndex = newIndex;
        }

        // InvokeAsync ensures thread safety in WASM
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleSeek(double time)
    {
        if (playerBar != null)
            await playerBar.SeekToTime(time);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
